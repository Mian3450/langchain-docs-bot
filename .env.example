# Copy to .env and fill in your own values. Never commit .env.

# --- Required secrets ---
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token-from-botfather
OPENAI_API_KEY=sk-your-openai-key

# --- Model configuration (optional, sane defaults) ---
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# --- RAG parameters ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# --- Paths ---
CHROMA_PERSIST_DIR=./data/chroma
RAW_DOCS_DIR=./data/raw

# --- Documentation source (GitHub) ---
# LangChain's OSS docs now live in the langchain-ai/docs repo under src/oss.
DOCS_REPO=langchain-ai/docs
DOCS_REF=main
DOCS_SUBDIR=src/oss

# --- Bot behavior ---
MAX_MESSAGE_LENGTH=4000
RATE_LIMIT_PER_MINUTE=10

# --- Logging ---
LOG_LEVEL=INFO
# json for production, console for local dev
LOG_FORMAT=console
