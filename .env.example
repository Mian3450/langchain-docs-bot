# Copy to .env and fill in your own values. Never commit .env.

# --- Required secrets ---
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token-from-botfather

# --- LLM provider key (required for the default llm_provider=groq) ---
# Free tier, no card required: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key

# --- Optional: OpenAI ---
# Only needed if you switch llm_provider or embedding_provider to "openai",
# or if you run scripts/eval_rag.py (DeepEval uses GPT-4 as the judge LLM).
# OPENAI_API_KEY=sk-your-openai-key

# --- Provider selection (defaults are free-tier) ---
# EMBEDDING_PROVIDER=fastembed     # or "openai"
# LLM_PROVIDER=groq                # or "openai"

# --- Model configuration (defaults match the providers above) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_MODEL=llama-3.1-8b-instant

# --- RAG parameters ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# --- Paths ---
CHROMA_PERSIST_DIR=./data/chroma
RAW_DOCS_DIR=./data/raw

# --- Documentation source (GitHub) ---
# LangChain's OSS docs now live in the langchain-ai/docs repo under src/oss.
DOCS_REPO=langchain-ai/docs
DOCS_REF=main
DOCS_SUBDIR=src/oss

# --- Bot behavior ---
MAX_MESSAGE_LENGTH=4000
RATE_LIMIT_PER_MINUTE=10

# --- Logging ---
LOG_LEVEL=INFO
# json for production, console for local dev
LOG_FORMAT=console
